# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Qwen on 0G compute (OpenAI-compatible endpoint). Same values you used for Mettle.
LLM_BASE_URL=https://compute-network-6.integratenetwork.work/v1/proxy
LLM_API_KEY=app-sk-...
LLM_MODEL=qwen/qwen-2.5-7b-instruct

# Arc testnet
ARC_RPC_URL=https://rpc.testnet.arc.network

# Judge wallets. The orchestrator signs each investment with the deciding judge's own
# key. JUDGE_A is Alpha (also in contracts/.env); JUDGE_B/C are Nova/Sable.
JUDGE_A_PRIVATE_KEY=0x...
JUDGE_B_PRIVATE_KEY=0x...
JUDGE_C_PRIVATE_KEY=0x...

# Operator/deployer key. Runs the admin scripts (setup, close-loop): deposits capital,
# registers judges, and stands in as the paying customer for x402 revenue.
DEPLOYER_PRIVATE_KEY=0x...

# Optional knobs for the admin scripts (defaults shown).
# DEPOSIT_USDC=15        # capital added to the Fund in `bun run setup`
# JUDGE_GAS_USDC=1       # gas top-up sent to each new judge wallet
# MANDATE_USDC=6         # per-judge spending mandate
# REVENUE_USDC=2         # simulated revenue per deal in `bun run close-loop`

# Startup wallets, for settling revenue back via RevenueShare in a later step.
# MeshRelay reuses the spike client wallet (CLIENT_PRIVATE_KEY from contracts/.env);
# the cold-start startups get their own throwaway keys.
CLIENT_PRIVATE_KEY=0x...
STARTUP_PIXELFORGE_PRIVATE_KEY=0x...
STARTUP_DATAORACLE_PRIVATE_KEY=0x...

# Circle Developer Controlled Wallets (Agent Stack). CIRCLE_API_KEY is a Sandbox
# Standard API key (format PREFIX:ID:SECRET). ENTITY_SECRET is the 32-byte hex secret
# you register once in the console; keep its recovery file safe, outside this repo.
CIRCLE_API_KEY=
ENTITY_SECRET=
