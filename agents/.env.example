# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Qwen on 0G compute (OpenAI-compatible endpoint). Same values you used for Mettle.
LLM_BASE_URL=https://compute-network-6.integratenetwork.work/v1/proxy
LLM_API_KEY=app-sk-...
LLM_MODEL=qwen/qwen-2.5-7b-instruct

# Arc testnet
ARC_RPC_URL=https://rpc.testnet.arc.network

# Judge wallet(s). The orchestrator signs each investment with the deciding judge's own
# key. Same key as JUDGE_A_PRIVATE_KEY in contracts/.env.
JUDGE_A_PRIVATE_KEY=0x...

# Startup wallets, for settling revenue back via RevenueShare in a later step.
# MeshRelay reuses the spike client wallet (CLIENT_PRIVATE_KEY from contracts/.env);
# the cold-start startups get their own throwaway keys.
CLIENT_PRIVATE_KEY=0x...
STARTUP_PIXELFORGE_PRIVATE_KEY=0x...
STARTUP_DATAORACLE_PRIVATE_KEY=0x...

# Optional (later layers): Circle Standard API key for Agent Stack wallet/x402 features
CIRCLE_API_KEY=
